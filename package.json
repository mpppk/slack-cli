{
	"name": "slack-cli",
	"module": "index.ts",
	"type": "module",
	"bin": {
		"slack-cli": "./index.ts"
	},
	"scripts": {
		"start": "bun index.ts",
		"type-check": "bunx tsc --noEmit",
		"format": "bunx biome format --write .",
		"lint": "bunx biome lint --write .",
		"check": "bunx biome check --write ."
	},
	"dependencies": {
		"@slack/web-api": "^7"
	},
	"devDependencies": {
		"@biomejs/biome": "latest",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
